# Epic SMART on FHIR – used when testing launch from Epic (sandbox or production).
# Get this from EMRAP/Epic app registration. Use non-production ID for local testing.
VITE_EPIC_CLIENT_ID=

# Optional: Epic patient chart URL template. When set, "Open in EMR" links are shown.
# Ask your Epic/EMRAP team for the exact URL format. Use {patientId} as placeholder.
# Example: https://your-epic-domain.org/patientchart?patientId={patientId}
# VITE_EPIC_CHART_URL_TEMPLATE=
